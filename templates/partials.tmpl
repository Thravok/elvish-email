{{define "site-assets"}}
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@300;400;500;700&amp;family=Plus+Jakarta+Sans:wght@400;500;600;700&amp;family=Space+Mono:wght@400;700&amp;family=Space+Grotesk:wght@400;700&amp;family=Anton&amp;display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/styles.css{{assetQ .Site}}"/>
<link rel="stylesheet" href="/page.css{{assetQ .Site}}"/>
<script src="/shared/api-config.js{{assetQ .Site}}"></script>
<script src="/shared/api-fetch.js{{assetQ .Site}}" defer></script>
<script src="/perf.js{{assetQ .Site}}" defer></script>
<script src="/site.js{{assetQ .Site}}" defer></script>
{{end}}

{{define "theme-boot"}}
<script>
(function () {
  var el = document.documentElement;
  function resolve(raw) {
    if (raw === "dark" || raw === "light") return raw;
    try {
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    } catch (e) {
      return "light";
    }
  }
  var raw = "light";
  if (el.hasAttribute("data-user-ui-theme")) {
    raw = el.getAttribute("data-user-ui-theme") || "auto";
  } else {
    try {
      var def = JSON.parse(document.getElementById("elvish-tweak-defaults").textContent);
      raw = def.theme || el.getAttribute("data-site-theme-default") || "light";
      try {
        var ls = JSON.parse(localStorage.getItem("elvish-tweaks-v1") || "{}");
        if (ls.theme) raw = ls.theme;
      } catch (e2) {}
    } catch (e) {
      raw = el.getAttribute("data-site-theme-default") || "light";
    }
  }
  el.setAttribute("data-theme", resolve(raw));
  el.setAttribute("data-theme-preference", raw);
})();
</script>
{{end}}

{{define "effects"}}
<div class="bg-ambient" id="fx-ambient" aria-hidden="true"></div>
<div class="bg-grid" id="fx-grid"></div>
<div class="scanline" id="fx-scan"></div>
<div class="crosshair"></div>
{{end}}

{{define "topbar"}}
<header class="topbar">
  <div class="topbar-left">
    <a href="/" class="brand" style="text-decoration:none;color:inherit"><span class="dot"></span>ELVISH</a>
    <span class="dim" style="font-size:10px">{{.Site.Version}}</span>
    <span class="dim" style="font-size:10px" id="topbar-glitch">NIGHTLY</span>
  </div>
  <nav class="topbar-center" aria-label="Main navigation">
    {{- range .Site.Nav}}
    <a href="{{.Href}}" class="navlink{{if .Active}} active{{end}}"{{if .Active}} aria-current="page"{{end}}>{{.Label}}</a>
    {{- end}}
  </nav>
  <div class="topbar-right">
    <div class="topbar-auth">
      {{- if .NavAuth.LoggedIn}}
      <span class="nav-session dim" title="{{.NavAuth.Email}}">{{if .NavAuth.Name}}{{.NavAuth.Name}}{{else}}{{.NavAuth.Email}}{{end}}</span>
      {{- if .NavAuth.IsAdmin}}
      <a href="/mail?view=admin" class="navlink">PANEL</a>
      {{- end}}
      <a href="/mail" class="navlink">MAIL</a>
      <form class="nav-inline-form" action="/auth/logout" method="post">
        <input type="hidden" name="next" value="{{.NavAuth.LogoutNext}}" />
        <button type="submit" class="navlink">LOGOUT</button>
      </form>
      {{- else}}
      <a href="/login" class="navlink">LOGIN</a>
      <a href="/register" class="navlink">REGISTER</a>
      {{- end}}
    </div>
    <span class="dim">UTC</span>
    <span id="topbar-utc">0000-00-00 00:00:00Z</span>
    <span class="tick">●</span>
  </div>
</header>
{{end}}

{{define "footer"}}
<footer class="footer">
  <div>
    <div class="ftk">// IDENT</div>
    <div class="brand" style="font-size:18px;margin-bottom:8px"><span class="dot"></span>ELVISH</div>
    <div class="dim">{{.Site.Footer.Tagline}}</div>
  </div>
  <div>
    <div class="ftk">// PAGES</div>
    <ul>
      {{- range .Site.Footer.Pages}}
      <li><a href="{{.Href}}">{{.Label}}</a></li>
      {{- end}}
    </ul>
  </div>
  <div>
    <div class="ftk">// PROTOCOL</div>
    <ul class="dim">
      {{- range .Site.Footer.Protocol}}
      <li>{{.}}</li>
      {{- end}}
    </ul>
  </div>
  {{- with .Site.Support.PublicSupportRows}}
  <div>
    <div class="ftk">// SUPPORT</div>
    <ul>
      {{- range .}}
      <li><a href="mailto:{{.Email}}">{{.Label}}</a></li>
      {{- end}}
    </ul>
  </div>
  {{- end}}
  <div>
    <div class="ftk">// SIGN</div>
    <div class="footer-ascii-clip"{{if .Site.Footer.ASCIIScaleToFit}} data-ascii-scale-fit="1"{{end}}>
    <pre class="ascii" style="margin:0;background:transparent;border:0;color:inherit;font:inherit">{{.Site.Footer.ASCIIBlock}}</pre>
    </div>
    <div class="dim" style="margin-top:10px;font-size:10px">// END OF FILE</div>
  </div>
</footer>
{{end}}

{{define "tweakfab"}}
<button type="button" id="elvish-tweak-fab" class="elvish-tweak-fab" aria-label="Tweaks">TWEAKS</button>
<div id="elvish-tweak-panel" class="elvish-tweak-panel" hidden></div>
<div id="elvish-konami-toast" class="konami-toast" hidden>DEV MODE ENGAGED · WELCOME, FRIEND</div>
{{end}}
