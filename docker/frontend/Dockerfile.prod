# Production frontend: static files + SSR proxy (no public /api proxy).
# Build context: repository root.

FROM nginx:1.27-alpine

RUN apk add --no-cache sed

COPY docker/frontend/nginx.prod.conf /etc/nginx/conf.d/default.conf
COPY docker/frontend/write-api-config.sh /docker-entrypoint.d/40-write-api-config.sh
RUN chmod +x /docker-entrypoint.d/40-write-api-config.sh
COPY static/ /usr/share/nginx/html/

EXPOSE 80
