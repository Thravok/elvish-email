/public/
/tmp/

# Go build output
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go module cache (CI uses .go/ as GOPATH)
/.go/
/.go-cache/

# Go test/coverage
*.test
*.out
coverage.html

# Minisign secret for blog posts (never commit; elvishsign keygen default name)
content/blog/signing.key

# Local data/secrets (generated by dev scripts)
/data/

# Environment files
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/

# Xcode — never commit per-machine UI state or account-derived paths (xcuserdata)
**/xcuserdata/
*.xcuserstate
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Flutter (generated under flutter/elvish_mail/; see flutter/elvish_mail/.gitignore)
flutter/**/.dart_tool/
flutter/**/build/
flutter/**/.flutter-plugins
flutter/**/.flutter-plugins-dependencies

# Playwright (e2e/)
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/.cache/

# Build artifacts from standalone binaries
/elvishmailtest
/elvishrelay
